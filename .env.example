# EduForge AI — Environment Variables
# Copy this file to .env and fill in your keys

# ─── OpenAI API ───────────────────────────────────────────────────────────────
# Create a project API key in the OpenAI Platform and paste it below
OPENAI_API_KEY=your_openai_project_key
GROQ_API_KEY=your_groq_api_key
AI_PROVIDER=openai
AI_API_KEY=your_custom_provider_key
AI_BASE_URL=https://your-provider.example/v1
AI_MODEL=your-model-name

# ─── Model ────────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4.1-mini
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true for the reliable cached judge demo. Set to false only with API billing.
DEMO_MODE=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
ALLOW_VERCEL_PREVIEWS=false
