# EduForge AI — Environment Variables
# Copy this file to .env and fill in your keys

# ─── Groq API (FREE) ──────────────────────────────────────────────────────────
# Sign up at https://console.groq.com — free, no credit card needed
# Create an API key and paste it below
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Model ────────────────────────────────────────────────────────────────────
# Best free model on Groq — fast, 128k context, supports JSON mode
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true to run without any API key (uses pre-generated demo data)
# Perfect for testing the UI before you get your Groq key
DEMO_MODE=false

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
